#!name=8se.me 终极去广告模块
#!desc=纯脚本接管版：完美放行视频与图片，精准定点消除弹窗与视觉广告。
#!category=去广告

[MITM]
hostname = %APPEND% 8se.me, *.8se.me

[Script]
# 仅保留这一个脚本，放行所有网络请求，由 JS 在前端进行手术式清理
8se_ad_killer = type=http-response,pattern=^https?:\/\/(www\.)?8se\.me\/,requires-body=1,max-size=0,timeout=10,script-path=https://github.com/lushier888/QX-Surge-Loon-Shadowrocket/raw/refs/heads/main/SurgeModule/8es.js
