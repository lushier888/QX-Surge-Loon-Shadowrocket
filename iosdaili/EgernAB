# ————ipv6与网络测速————
ipv6: true
allow_external_connections: false
vif_only: true
geoip_db_url: https://github.com/Hackl0us/GeoIP2-CN/raw/release/Country.mmdb
proxy_latency_test_url: http://www.apple.com/library/test/success.html
direct_latency_test_url: http://www.baidu.com
compat_route: false

# ————网络DNS————
