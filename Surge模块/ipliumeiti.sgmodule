#!name=IP和流媒体信息
#!desc=节点地理信息与主流流媒体解锁状态检测。
#!category=工具

[Panel]
# 面板显示名称：流媒体检测
liumeiti_panel = script-name=liumeiti_script, update-interval=43200

[Script]
# 引用你 GitHub 上的 js 文件
liumeiti_script = type=generic, timeout=15, script-path=https://raw.githubusercontent.com/lushier888/QX-Surge-Loon-Shadowrocket/main/liumeiti.js
